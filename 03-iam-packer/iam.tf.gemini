# ==========================================================
# 1. INSTANCE SIDE: Role for the EC2 / Packer Build
# ==========================================================

# The Trusted Role that the EC2 instance will "wear"
resource "aws_iam_role" "packer_instance_role" {
  name = "packer-ssm-instance-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action = "sts:AssumeRole"
      Effect = "Allow"
      Principal = { Service = "ec2.amazonaws.com" }
    }]
  })
}

# Attach the standard AWS Managed Policy for SSM
resource "aws_iam_role_policy_attachment" "ssm_core_attach" {
  role       = aws_iam_role.packer_instance_role.name
  policy_arn = "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
}

# The Profile that actually gets attached to the Instance in Packer
resource "aws_iam_instance_profile" "packer_instance_profile" {
  name = "packer-ssm-instance-profile"
  role = aws_iam_role.packer_instance_role.name
}


# ==========================================================
# 2. USER SIDE: Permissions for you to Log In
# ==========================================================

# Define the "Admin" Group
resource "aws_iam_group" "admins" {
  name = "packer-admins"
}

# Create the specific Policy that allows Session Manager access
resource "aws_iam_policy" "ssm_user_login_policy" {
  name        = "SSM-User-Login-Policy"
  description = "Allows starting an SSM session on instances with AutoStop tag"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = "ssm:StartSession"
        Resource = "arn:aws:ec2:*:*:instance/*"
        Condition = {
          StringEquals = { "aws:ResourceTag/AutoStop": "true" }
        }
      },
      {
        Effect   = "Allow"
        Action   = [
          "ssm:TerminateSession",
          "ssm:ResumeSession"
        ]
        Resource = "arn:aws:ssm:*:*:session/$${aws:username}-*"
      }
    ]
  })
}

# ATTACH the Policy to the Group
resource "aws_iam_group_policy_attachment" "admin_ssm_attach" {
  group      = aws_iam_group.admins.name
  policy_arn = aws_iam_policy.ssm_user_login_policy.arn
}

# ADD your user to the Group
resource "aws_iam_user_group_membership" "admin_membership" {
  user = "YOUR_IAM_USERNAME" # <--- CHANGE THIS to your actual AWS IAM Username

  groups = [
    aws_iam_group.admins.name
  ]
}